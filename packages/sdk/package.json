{
  "name": "@praman-network/sdk",
  "version": "0.1.10",
  "license": "MIT",
  "type": "module",
  "keywords": [
    "web3",
    "authentication",
    "zk-snark",
    "identity",
    "biometric",
    "passwordless",
    "polygon",
    "decentralized-auth"
  ],
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch"
  },
  "dependencies": {
    "@lit-protocol/lit-node-client": "^7.4.0",
    "@mediapipe/tasks-vision": "^0.10.35",
    "ethers": "^6.17.0",
    "snarkjs": "^0.7.6"
  },
  "peerDependencies": {
    "react": "^18.0.0 || ^19.0.0",
    "tslib": "^2.0.0"
  },
  "devDependencies": {
    "tsup": "^8.0.2",
    "typescript": "^5.0.0"
  },
  "files": [
    "dist",
    "README.md",
    "package.json"
  ]
}
